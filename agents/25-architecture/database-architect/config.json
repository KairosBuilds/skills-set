{
  "agent": {
    "name": "database-architect",
    "version": "1.1.0",
    "status": "production"
  },
  "execution": {
    "max_output_tokens": 24000,
    "include_diagrams": true,
    "include_explain_analysis": true
  },
  "design": {
    "default_database": "postgresql",
    "normalization_target": "3nf",
    "require_index_strategy": true,
    "include_migration_plan": true
  },
  "output": {
    "format": "document",
    "include_erd": true,
    "include_ddl": true,
    "include_query_examples": true,
    "include_performance_analysis": true
  }
}
