{
  "agent": {
    "name": "system-architect",
    "version": "1.1.0",
    "status": "production"
  },
  "execution": {
    "max_output_tokens": 32000,
    "include_diagrams": true,
    "include_sla_definitions": true
  },
  "design": {
    "scalability_model": "horizontal",
    "reliability_target": "99.99",
    "require_failure_mode_analysis": true,
    "require_capacity_planning": true
  },
  "output": {
    "format": "document",
    "include_scalability_plan": true,
    "include_disaster_recovery": true,
    "include_monitoring_strategy": true
  }
}
