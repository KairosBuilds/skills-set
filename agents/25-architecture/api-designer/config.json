{
  "agent": {
    "name": "api-designer",
    "version": "1.1.0",
    "status": "production"
  },
  "execution": {
    "max_output_tokens": 24000,
    "generate_specification": true,
    "specification_format": "openapi_3_1"
  },
  "design": {
    "default_protocol": "rest",
    "include_examples": true,
    "include_error_handling": true,
    "include_security": true
  },
  "output": {
    "format": "document_with_spec",
    "include_spec_file": true,
    "include_documentation": true,
    "include_sdk_snippets": true
  }
}
