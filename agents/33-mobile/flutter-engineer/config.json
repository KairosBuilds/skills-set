{
  "agent": {
    "name": "flutter-engineer",
    "version": "1.0.0",
    "priority": "high",
    "cost": "medium",
    "status": "production"
  },
  "engine": {
    "type": "claude-code",
    "model": "claude-sonnet-4",
    "maxTokens": 64000,
    "temperature": 0.3
  },
  "workflow": {
    "stages": ["plan", "implement", "build", "test", "review"],
    "autoReview": true,
    "requireTests": true
  },
  "build": {
    "ios": {
      "buildConfig": "release",
      "exportMethod": "app-store"
    },
    "android": {
      "buildTypes": ["release", "profile"]
    },
    "web": {
      "renderer": "canvaskit"
    }
  },
  "testing": {
    "runner": "flutter_test",
    "coverage": 80,
    "integration": "integration_test"
  }
}
