{
  "agent": {
    "name": "appium-engineer",
    "version": "1.0.0",
    "priority": "medium",
    "cost": "medium",
    "status": "stable"
  },
  "engine": {
    "type": "claude-code",
    "model": "claude-sonnet-4",
    "maxTokens": 64000,
    "temperature": 0.3
  },
  "workflow": {
    "stages": ["plan", "setup", "write", "run", "report"],
    "autoReview": true,
    "requireTests": false
  },
  "appium": {
    "version": "2.x",
    "serverPort": 4723,
    "implicitWait": 10,
    "timeouts": {
      "command": 60,
      "launch": 120
    }
  },
  "testing": {
    "runner": "pytest",
    "reporting": "allure",
    "parallelism": true
  }
}
