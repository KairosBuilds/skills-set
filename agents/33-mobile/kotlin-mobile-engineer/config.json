{
  "agent": {
    "name": "kotlin-mobile-engineer",
    "version": "1.0.0",
    "priority": "high",
    "cost": "medium",
    "status": "production"
  },
  "engine": {
    "type": "claude-code",
    "model": "claude-sonnet-4",
    "maxTokens": 64000,
    "temperature": 0.3
  },
  "workflow": {
    "stages": ["plan", "implement", "build", "test", "review"],
    "autoReview": true,
    "requireTests": true
  },
  "build": {
    "kotlinVersion": "1.9.x",
    "agpVersion": "8.x",
    "shared": {
      "androidTarget": true,
      "iosTarget": true,
      "desktopTarget": false
    }
  },
  "testing": {
    "unit": "kotlin-test",
    "integration": "androidx-test",
    "coverage": 75
  }
}
