{
  "agent": {
    "name": "react-native-engineer",
    "version": "1.0.0",
    "priority": "critical",
    "cost": "high",
    "status": "production"
  },
  "engine": {
    "type": "claude-code",
    "model": "claude-sonnet-4",
    "maxTokens": 64000,
    "temperature": 0.3
  },
  "workflow": {
    "stages": ["plan", "implement", "build", "test", "review"],
    "autoReview": true,
    "requireTests": true
  },
  "build": {
    "metro": {
      "resetCache": true,
      "maxWorkers": 4
    },
    "expo": {
      "prebuild": true,
      "tunnel": false
    }
  },
  "testing": {
    "runner": "jest",
    "coverage": 80,
    "e2e": "detox"
  }
}
