{
  "agent": "prompt-optimizer",
  "version": "1.0.0",
  "max_concurrent_tasks": 10,
  "timeout_seconds": 120,
  "retry_on_failure": true,
  "max_retries": 2,
  "default_model": "gpt-4o-mini",
  "temperature": 0.2,
  "output_token_limit": 2048,
  "logging": {
    "level": "info",
    "format": "json"
  },
  "features": {
    "token_counting": true,
    "compression": true,
    "accuracy_check": true,
    "ab_testing": false
  }
}
