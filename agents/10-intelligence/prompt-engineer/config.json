{
  "agent": "prompt-engineer",
  "version": "1.0.0",
  "max_concurrent_tasks": 5,
  "timeout_seconds": 300,
  "retry_on_failure": true,
  "max_retries": 3,
  "default_model": "gpt-4",
  "temperature": 0.3,
  "output_token_limit": 4096,
  "logging": {
    "level": "info",
    "format": "json"
  },
  "features": {
    "chain_of_thought": true,
    "few_shot_generation": true,
    "structured_output": true,
    "prompt_template_library": true
  }
}
