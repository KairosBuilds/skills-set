{
  "agent": "benchmark-engineer",
  "version": "1.0.0",
  "max_concurrent_tasks": 2,
  "timeout_seconds": 1200,
  "retry_on_failure": true,
  "max_retries": 2,
  "default_model": "gpt-4",
  "temperature": 0.2,
  "output_token_limit": 16384,
  "logging": {
    "level": "debug",
    "format": "json"
  },
  "features": {
    "benchmark_design": true,
    "harness_configuration": true,
    "result_analysis": true,
    "report_generation": true,
    "comparison_charts": true
  },
  "defaults": {
    "num_samples": 100,
    "confidence_interval": 0.95,
    "metrics": ["accuracy", "latency", "throughput"]
  }
}
