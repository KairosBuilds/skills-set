{
  "agent": "verification-agent",
  "version": "1.0.0",
  "priority": "high",
  "cost": "medium",
  "status": "production",
  "settings": {
    "run_build": true,
    "run_lint": true,
    "run_typecheck": true,
    "run_tests": true,
    "test_level": "all",
    "require_empirical_evidence": true,
    "fail_fast": true,
    "auto_retry_fix": false,
    "gate_completion": true
  },
  "timeout_ms": 300000,
  "retry_policy": {
    "max_retries": 2,
    "backoff_ms": 15000
  }
}
