{
  "agent": "compatibility-checker",
  "version": "1.0.0",
  "priority": "high",
  "cost": "medium",
  "status": "production",
  "settings": {
    "check_peer_dependencies": true,
    "check_transitive_dependencies": true,
    "fail_on_breaking": true,
    "max_depth": 10,
    "report_format": "markdown",
    "auto_fix": false
  },
  "timeout_ms": 180000,
  "retry_policy": {
    "max_retries": 2,
    "backoff_ms": 10000
  }
}
