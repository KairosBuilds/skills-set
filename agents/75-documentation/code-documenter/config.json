{
  "name": "code-documenter",
  "version": "1.0.0",
  "description": "Generates inline code documentation comments",
  "priority": "medium",
  "cost": "low",
  "status": "stable",
  "settings": {
    "output_format": "jsdoc",
    "include_types": true,
    "include_examples": false,
    "include_throws": true,
    "include_see_also": true,
    "max_line_length": 80,
    "document_private": false,
    "document_internal": true
  }
}
